---
export const prerender = true;

import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

type SpaceId = "full-terrace" | "half-terrace";

const spaceMeta: Record<SpaceId, { title: string; description: string }> = {
  "full-terrace": { title: "Experiencia Terraza Completa — Málaga Terrace", description: "Espacio exterior exclusivo en azotea para hasta 120 personas con vistas panorámicas al mar, barra completa y catering personalizado en Innovation Campus Málaga." },
  "half-terrace": { title: "Experiencia Media Terraza — Málaga Terrace", description: "Media terraza exclusiva en azotea para hasta 60 personas con vistas al mar, servicio de barra y catering en Innovation Campus Málaga." },
};

export function getStaticPaths() {
  return [
    { params: { space: 'full-terrace' } },
    { params: { space: 'half-terrace' } },
  ];
}

const { space } = Astro.params as { space: SpaceId };
const meta = spaceMeta[space];
const path = `/es/terraza-privada/${space}`;
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout title={meta.title} description={meta.description} {path} {breadcrumb} lang="es">
  <MeetingRoomPage roomSlug={space} lang="es" client:load />
</RoomPageLayout>
