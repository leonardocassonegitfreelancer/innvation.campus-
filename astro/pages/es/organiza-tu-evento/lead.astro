---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '@/components/landing/Navbar';
import Footer from '../../../components/Footer.astro';
import EventLeadCapture from '@/pages/es/EventLeadCapture';

const path = '/es/organiza-tu-evento/lead';
const title = 'Cuéntanos sobre tu Evento';
const description = 'Comparte los detalles de tu próximo evento en Innovation Campus Málaga.';
---
<Layout {title} {description} {path} noIndex>
  <div class="overflow-x-hidden">
    <Navbar lang="es" client:load />
    <EventLeadCapture lang="es" client:load />
    <Footer lang="es" />
  </div>
</Layout>
