---
export const prerender = true;

import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import ThankYouContact from '@/pages/en/ThankYouContact';

type ServiceKey = "event" | "private-office" | "coworking" | "business-registration" | "general";

export function getStaticPaths() {
  return [
    { params: { service: 'event' } },
    { params: { service: 'private-office' } },
    { params: { service: 'coworking' } },
    { params: { service: 'business-registration' } },
    { params: { service: 'general' } },
  ];
}

const { service } = Astro.params as { service: ServiceKey };
const path = `/es/gracias/${service}`;
---
<RoomPageLayout title="Gracias" {path} noIndex lang="es">
  <ThankYouContact lang="es" service={service} client:load />
</RoomPageLayout>
