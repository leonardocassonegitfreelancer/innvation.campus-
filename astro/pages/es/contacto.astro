---
import RoomPageLayout from '../../components/RoomPageLayout.astro';
import Contact from '@/pages/en/Contact';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/contacto';
const title = 'Contacto';
const description = 'Contáctanos en Innovation Campus. Rellena el formulario o visítanos en cualquiera de nuestras sedes.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {alternates} {breadcrumb} lang="es">
  <Contact lang="es" client:load />
</RoomPageLayout>
