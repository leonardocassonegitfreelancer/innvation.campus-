---
import Layout from '../../layouts/Layout.astro';
import Navbar from '@/components/landing/Navbar';
import Footer from '../../components/Footer.astro';
import Olbia from '@/pages/en/Olbia';
import { getAlternateLinks, generateBreadcrumbJsonLd, generateLocalBusinessJsonLd } from '@/lib/i18n';

const path = '/es/olbia';
const title = 'Espacio de Coworking en Olbia';
const description = 'Un espacio de coworking moderno en Olbia, Cerdeña.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
const jsonLd = generateLocalBusinessJsonLd('olbia', `https://innovationcampus.biz${path}`);
---
<Layout {title} {description} {path} {alternates} {breadcrumb} {jsonLd}>
  <div class="overflow-x-hidden">
    <Navbar lang="es" client:load />
    <Olbia lang="es" client:load />
    <Footer lang="es" />
  </div>
</Layout>
