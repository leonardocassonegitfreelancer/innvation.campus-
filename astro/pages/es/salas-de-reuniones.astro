---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import ConferenceIntro from '@/components/landing/ConferenceIntro';
import ConferenceRooms from '@/components/landing/ConferenceRooms';
import EventSocialProof from '@/components/landing/EventSocialProof';
import ServicePhotoGrid from '../../components/ServicePhotoGrid.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import ScrollAnimate from '../../components/ScrollAnimate.astro';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';
import serviceMeeting from '@/assets/service-meeting.webp';
import serviceCoworking from '@/assets/service-coworking.webp';
import servicePrivate from '@/assets/service-private.webp';
import serviceCommunity from '@/assets/service-community.webp';
import serviceTerrace from '@/assets/service-terrace.webp';

const path = '/es/salas-de-reuniones';
const title = 'Salas de Reuniones';
const subtitle = 'Espacios de reunión profesionales con opciones de catering para equipos de todos los tamaños.';
const description = 'Espacios de reunión profesionales con opciones de catering para equipos de todos los tamaños en Málaga.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  {subtitle}
  image={serviceMeeting}
  lang="es"
>
  <ConferenceIntro lang="es" client:load />
  <EventSocialProof lang="es" client:visible />
  <ConferenceRooms lang="es" client:visible />
  <QuoteSection lang="es" variant="meeting" />

  <ServicePhotoGrid
    eyebrow="También disponible en esta ubicación"
    title="Otros Espacios y Servicios"
    items={[
      { label: "Organiza Tu Evento", href: "/es/organiza-tu-evento", image: serviceCommunity },
      { label: "Terraza Privada", href: "/es/terraza-privada", image: serviceTerrace },
      { label: "Coworking", href: "/es/coworking", image: serviceCoworking },
      { label: "Oficinas Privadas", href: "/es/oficinas-privadas", image: servicePrivate },
    ]}
  />

  <ScrollAnimate />
</ServicePageLayout>
