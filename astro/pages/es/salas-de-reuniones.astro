---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import ConferenceIntro from '@/components/landing/ConferenceIntro';
import ConferenceRooms from '@/components/landing/ConferenceRooms';
import ConferenceIncludes from '../../components/ConferenceIncludes.astro';
import QuickLinksSection from '../../components/QuickLinksSection.astro';
import ScrollAnimate from '../../components/ScrollAnimate.astro';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';
import serviceMeeting from '@/assets/service-meeting.webp';

const path = '/es/salas-de-reuniones';
const title = 'Salas de Reuniones';
const subtitle = 'Espacios de reunión profesionales con opciones de catering para equipos de todos los tamaños.';
const description = 'Espacios de reunión profesionales con opciones de catering para equipos de todos los tamaños en Málaga.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  {subtitle}
  image={serviceMeeting}
  lang="es"
>
  <ConferenceIntro lang="es" client:load />
  <ConferenceRooms lang="es" client:visible />
  <ConferenceIncludes lang="es" />
  <QuickLinksSection
    eyebrow="Explorar"
    title="Otros espacios y servicios"
    links={[
      { label: "Organiza Tu Evento", description: "Alquiler de espacio privado para cualquier ocasión", href: "/es/organiza-tu-evento" },
      { label: "Terraza Privada", description: "Terraza con vistas al mar", href: "/es/terraza-privada" },
      { label: "Coworking", description: "Escritorios flexibles y membresías", href: "/es/coworking" },
      { label: "Oficinas Privadas", description: "Oficinas dedicadas para tu equipo", href: "/es/oficinas-privadas" },
      { label: "Málaga Palace", description: "Ubicación en el Centro Histórico", href: "/es/malaga-palace" },
      { label: "Contacto", description: "Haz una pregunta o reserva una visita", href: "/es/contacto" },
    ]}
  />
  <ScrollAnimate />
</ServicePageLayout>
