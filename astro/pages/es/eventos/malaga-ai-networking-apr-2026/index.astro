---
import Layout from '../../../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/es/events/MalagaAIApr2026';
const path = '/es/eventos/malaga-ai-networking-apr-2026';
const title = 'Malaga AI Networking Night — Abril 2026';
const description = 'Una noche de conversaciones, demos y networking dedicada a la inteligencia artificial en Innovation Campus Málaga Palace. 23 de Abril de 2026.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {breadcrumb}>
  <PageWrapper lang="es" path={path} client:load><Page /></PageWrapper>
</Layout>
