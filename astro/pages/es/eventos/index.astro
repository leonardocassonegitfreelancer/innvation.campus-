---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import EventsHub from '@/components/landing/EventsHub';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/eventos';
const title = 'Eventos Comunitarios — Innovation Campus';
const description = 'Únete a talleres, charlas, networking y eventos comunitarios en Innovation Campus Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<RoomPageLayout {title} {description} {path} {breadcrumb} lang="es">
  <EventsHub lang="es" client:load />
</RoomPageLayout>
