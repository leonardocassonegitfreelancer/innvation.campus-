---
import Layout from '../../../layouts/Layout.astro';
import GalleryEventsPage from '@/pages/en/GalleryEvents';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/galeria/eventos';
const title = 'Galería de Eventos';
const description = 'Fotos de eventos comunitarios, noches de networking, talleres y charlas en Innovation Campus Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<Layout {title} {description} {path} {breadcrumb}>
  <GalleryEventsPage lang="es" client:load />
</Layout>
