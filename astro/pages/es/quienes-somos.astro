---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import AboutUs from '@/pages/en/AboutUs';
import aboutCampus from '@/assets/palace-outside-front.webp';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/quienes-somos';
const title = 'Quiénes Somos';
const description = 'Innovation Campus crea espacios de trabajo inspiradores y cultiva comunidades emprendedoras internacionales en España e Italia.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  subtitle="Espacios inspiradores. Comunidad internacional. Impacto real."
  image={aboutCampus}
  lang="es"
>
  <AboutUs lang="es" client:load />
</ServicePageLayout>
