---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/salas/gran-sala-conferencias';
const title = 'Gran Sala de Conferencias';
const description = 'Nuestra sala principal para hasta 80 personas con pantalla 4K de 85", videoconferencia premium y disposición flexible en Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="es">
  <MeetingRoomPage roomSlug="big-conference-room" lang="es" client:load />
</RoomPageLayout>
