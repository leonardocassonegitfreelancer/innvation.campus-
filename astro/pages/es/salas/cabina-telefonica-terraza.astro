---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/salas/cabina-telefonica-terraza';
const title = 'Cabina Telefónica — Málaga Terrace';
const description = 'Cabina telefónica privada e insonorizada para 1–2 personas en Innovation Campus Málaga Terrace. Perfecta para llamadas confidenciales y videorreuniones rápidas.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="es">
  <MeetingRoomPage roomSlug="phone-booth-terrace" lang="es" client:load />
</RoomPageLayout>
