---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/salas/gran-sala-conferencias-2';
const title = 'Large Conference Room';
const description = 'Sala versátil para hasta 50 personas (44 sillas). 48m² en planta baja con proyector, micrófono, pizarra y altavoz. Catering y eventos disponibles en Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="es">
  <MeetingRoomPage roomSlug="large-conference-room" lang="es" client:load />
</RoomPageLayout>
