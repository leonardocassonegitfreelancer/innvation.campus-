---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/oficinas-privadas/palace-small';
const title = 'Oficina Privada Pequeña — Málaga Palace';
const description = 'Una acogedora oficina privada para 1–3 personas en el corazón histórico de Málaga. Luz natural, entrada privada, WiFi de alta velocidad.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="es">
  <OfficeDetailPage officeSlug="palace-small" lang="es" client:load />
</RoomPageLayout>
