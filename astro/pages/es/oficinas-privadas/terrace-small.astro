---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/es/oficinas-privadas/terrace-small';
const title = 'Oficina Privada Pequeña — Málaga Terrace';
const description = 'Una luminosa oficina privada para 1–3 personas con vistas al mar en la sede Málaga Terrace. Acabados modernos, luz del mar y todas las comodidades.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="es">
  <OfficeDetailPage officeSlug="terrace-small" lang="es" client:load />
</RoomPageLayout>
