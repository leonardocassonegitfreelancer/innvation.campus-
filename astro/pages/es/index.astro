---
import Layout from '../../layouts/Layout.astro';
import { getAlternateLinks } from '@/lib/i18n';
import ScrollAnimate from '../../components/ScrollAnimate.astro';

// Astro static components (zero JS)
import AboutSnippet from '../../components/AboutSnippet.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import LocationsSection from '../../components/LocationsSection.astro';
import HomeCTA from '../../components/HomeCTA.astro';
import FooterSection from '../../components/Footer.astro';
import IntroStrip from '../../components/IntroStrip.astro';

// React islands (hydrated selectively)
import Navbar from '@/components/landing/Navbar';
import MainHero from '@/components/landing/MainHero';
import HeroTimedCards from '@/components/HeroTimedCards';
import ServicesSection from '@/components/landing/es/ServicesSectionES';
import FAQSection from '@/components/landing/es/FAQSectionES';

// Desktop hero imagery (the curated hero shots) — historic → modern → people
import palaceCourtyard from '@/assets/palace-courtyard.webp';
import terraceCoworkingAlt from '@/assets/terrace-coworking-alt.webp';
import serviceCommunity from '@/assets/service-community.webp';
import palaceEntrance from '@/assets/palace-entrance.webp';
import terraceBar from '@/assets/terrace-bar.webp';
const heroImages = [palaceCourtyard, terraceCoworkingAlt, serviceCommunity, palaceEntrance, terraceBar].map((i) => i.src);

const path = '/es';
const title = 'Oficinas - Coworking - Eventos';
const description = 'Dos espacios de coworking en Málaga, España. Uno en el centro histórico, otro junto al mar. Encuentra tu ritmo en Innovation/Campus.';
const alternates = getAlternateLinks(path);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CoworkingSpace",
  "name": "Innovation Campus",
  "description": "Dos espacios de coworking en Málaga, España. Uno en el centro histórico, otro junto al mar.",
  "url": "https://innovationcampus.biz/es",
  "address": [
    { "@type": "PostalAddress", "addressLocality": "Málaga", "addressCountry": "ES" },
    { "@type": "PostalAddress", "addressLocality": "Ancona", "addressCountry": "IT" }
  ],
  "openingHours": ["Mo-Th 09:30-18:30", "Fr 09:30-17:00"]
};
---
<Layout {title} {description} {path} {alternates} {jsonLd}>
  <main class="overflow-x-hidden">
    <Navbar lang="es" client:load />

    <!-- Hero — desktop: cycling artwork cards; mobile: existing video hero -->
    <div class="hidden md:block">
      <HeroTimedCards
        images={heroImages}
        line1="Donde la ambición"
        highlight="encuentra"
        line2="el mar."
        description="Dos espacios de coworking en Málaga — uno en el centro histórico, otro junto al mar."
        ctas={[{ label: "Explorar Servicios", href: "#services" }, { label: "Contáctanos", href: "/es/contacto" }]}
        accent="hsl(var(--primary))"
        accentForeground="#ffffff"
        overlay={0.32}
        maxStack={2}
        client:load
      />
    </div>
    <div class="md:hidden">
      <MainHero lang="es" client:load />
    </div>

    <IntroStrip lang="es" />

    <ServicesSection client:visible />

    <QuoteSection lang="es" />

    <LocationsSection lang="es" />

    <AboutSnippet lang="es" />

    <FAQSection client:load />

    <HomeCTA lang="es" />

    <FooterSection lang="es" />
  </main>

  <ScrollAnimate />
</Layout>
