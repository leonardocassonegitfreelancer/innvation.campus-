---
import Layout from '../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/es/Index';
const path = '/es';
const title = 'Oficinas - Coworking - Eventos';
const description = 'Dos espacios de coworking en Málaga, España. Uno en el centro histórico, otro junto al mar. Encuentra tu ritmo en Innovation/Campus.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {alternates} {breadcrumb}>
  <PageWrapper lang="es" path={path} client:load><Page /></PageWrapper>
</Layout>
