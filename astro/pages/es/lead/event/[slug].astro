---
export const prerender = true;

import RoomPageLayout from '../../../../components/RoomPageLayout.astro';
import EventLeadThankYou from '@/components/landing/EventLeadThankYou';
import { eventsDataset } from '@/data/events';

export function getStaticPaths() {
  return eventsDataset.map(e => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params as { slug: string };
const path = `/es/lead/event/${slug}`;
---

<RoomPageLayout title="Te estamos redirigiendo…" description="" {path} lang="es">
  <EventLeadThankYou {slug} lang="es" client:load />
</RoomPageLayout>
