---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import BusinessRegistrationPage from '@/pages/en/BusinessRegistration';
import serviceRegistration from '@/assets/service-registration.webp';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/business-registration';
const title = 'Business Registration';
const description = 'Relocate your business to Spain or Italy with our registration services at Innovation Campus.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  subtitle="Relocate your business to Spain or Italy with our registration services."
  image={serviceRegistration}
  lang="en"
>
  <BusinessRegistrationPage lang="en" client:load />
</ServicePageLayout>
