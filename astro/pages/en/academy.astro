---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import AcademyPage from '@/pages/en/Academy';
import serviceAcademy from '@/assets/service-academy.webp';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/academy';
const title = 'Academy';
const description = 'Workshops, courses, and training to help you grow at Innovation Campus.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  subtitle="Workshops, courses, and training to help you get better day by day."
  image={serviceAcademy}
  lang="en"
>
  <AcademyPage lang="en" client:load />
</ServicePageLayout>
