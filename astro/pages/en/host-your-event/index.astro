---
import Layout from '../../../layouts/Layout.astro';
import HostYourEventPage from '@/pages/en/HostYourEvent';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/host-your-event';
const title = 'Host Your Event';
const description = 'Host your next event at Innovation Campus. Unique venues in Málaga for conferences, workshops, networking, and private celebrations.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<Layout {title} {description} {path} {alternates} {breadcrumb}>
  <HostYourEventPage lang="en" client:load />
</Layout>
