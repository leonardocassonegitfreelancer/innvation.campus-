---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/private-offices/palace-small';
const title = 'Small Private Office — Málaga Palace';
const description = 'A charming 1–3 person private office in the historic heart of Málaga. Natural light, private entrance, high-speed WiFi at Innovation Campus Palace.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <OfficeDetailPage officeSlug="palace-small" lang="en" client:load />
</RoomPageLayout>
