---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/private-offices/terrace-small';
const title = 'Small Private Office — Málaga Terrace';
const description = 'A bright 1–3 person private office with ocean views at the Málaga Terrace location. Modern fit-out, sea light, and full amenities at Innovation Campus.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <OfficeDetailPage officeSlug="terrace-small" lang="en" client:load />
</RoomPageLayout>
