---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/private-offices/terrace-medium';
const title = 'Medium Private Office — Málaga Terrace';
const description = 'An open-plan 4–8 person office on the 4th floor with partial sea views at Málaga Terrace. Bright, collaborative, and steps from the Mediterranean.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <OfficeDetailPage officeSlug="terrace-medium" lang="en" client:load />
</RoomPageLayout>
