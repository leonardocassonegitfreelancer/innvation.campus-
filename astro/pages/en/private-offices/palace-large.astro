---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/private-offices/palace-large';
const title = 'Large Private Office — Málaga Palace';
const description = 'A fully accessible 9–15 person private office suite in Málaga\'s most iconic historic building. Event-ready with optional catering at Innovation Campus.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <OfficeDetailPage officeSlug="palace-large" lang="en" client:load />
</RoomPageLayout>
