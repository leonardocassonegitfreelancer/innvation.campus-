---
import Layout from '../../layouts/Layout.astro';
import Navbar from '@/components/landing/Navbar';
import Footer from '../../components/Footer.astro';
import Contact from '@/pages/en/Contact';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/contact';
const title = 'Contact Us';
const description = 'Get in touch with Innovation Campus. Fill in our contact form or visit us directly at any of our locations.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {alternates} {breadcrumb}>
  <div class="overflow-x-hidden">
    <Navbar lang="en" client:load />
    <Contact lang="en" client:load />
    <Footer lang="en" />
  </div>
</Layout>
