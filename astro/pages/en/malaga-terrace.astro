---
import Layout from '../../layouts/Layout.astro';
import Navbar from '@/components/landing/Navbar';
import Footer from '../../components/Footer.astro';
import MalagaTerrace from '@/pages/en/MalagaTerrace';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/malaga-terrace';
const title = 'Málaga Terrace';
const description = 'Seaside coworking with panoramic rooftop terrace in Málaga.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {alternates} {breadcrumb}>
  <div class="overflow-x-hidden">
    <Navbar lang="en" client:load />
    <MalagaTerrace lang="en" client:load />
    <Footer />
  </div>
</Layout>
