---
export const prerender = true;

import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import TerraceSpaceDetail from '@/pages/en/TerraceSpaceDetail';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

type SpaceId = "full-terrace" | "half-terrace";

const spaceMeta: Record<SpaceId, { title: string; description: string }> = {
  "full-terrace": { title: "Full Terrace Experience — Málaga Terrace", description: "Exclusive outdoor rooftop venue for up to 120 guests with panoramic sea views, full bar and custom catering at Innovation Campus Málaga." },
  "half-terrace": { title: "Half Terrace Experience — Málaga Terrace", description: "Exclusive half-terrace on the rooftop for up to 60 guests with sea views, bar service and catering at Innovation Campus Málaga." },
};

export function getStaticPaths() {
  return [
    { params: { space: 'full-terrace' } },
    { params: { space: 'half-terrace' } },
  ];
}

const { space } = Astro.params as { space: SpaceId };
const meta = spaceMeta[space];
const path = `/en/private-terrace/${space}`;
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout title={meta.title} description={meta.description} {path} {breadcrumb} lang="en">
  <TerraceSpaceDetail lang="en" spaceId={space} client:load />
</RoomPageLayout>
