---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import AboutUs from '@/pages/en/AboutUs';
import aboutCampus from '@/assets/palace-outside-front.webp';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/about-us';
const title = 'About Us';
const description = 'Innovation Campus creates inspiring workspaces and cultivates international business-minded communities across Spain and Italy.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  subtitle="Inspiring workspaces. International community. Real impact."
  image={aboutCampus}
  lang="en"
>
  <AboutUs lang="en" client:load />
</ServicePageLayout>
