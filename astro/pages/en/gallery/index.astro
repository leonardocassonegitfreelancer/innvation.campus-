---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import GalleryPage from '@/pages/en/Gallery';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/gallery';
const title = 'Gallery';
const description = 'Browse photos of our spaces and community events across Málaga, Ancona and Olbia.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <GalleryPage lang="en" client:load />
</RoomPageLayout>
