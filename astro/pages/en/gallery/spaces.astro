---
import Layout from '../../../layouts/Layout.astro';
import GallerySpacesPage from '@/pages/en/GallerySpaces';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/gallery/spaces';
const title = 'Spaces Gallery';
const description = 'Explore our coworking spaces, meeting rooms, and venues across Málaga, Ancona and Olbia.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<Layout {title} {description} {path} {breadcrumb}>
  <GallerySpacesPage lang="en" client:load />
</Layout>
