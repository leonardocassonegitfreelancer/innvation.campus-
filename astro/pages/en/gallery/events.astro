---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import GalleryEventsPage from '@/pages/en/GalleryEvents';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/gallery/events';
const title = 'Events Gallery';
const description = 'Photos from community events, networking nights, workshops and talks at Innovation Campus Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <GalleryEventsPage lang="en" client:load />
</RoomPageLayout>
