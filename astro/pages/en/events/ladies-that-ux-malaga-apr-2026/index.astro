---
import Layout from '../../../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/en/events/LadiesThatUXApr2026';
const path = '/en/events/ladies-that-ux-malaga-apr-2026';
const title = 'Ladies That UX Málaga: Inclusive Digital Design & Accessibility';
const description = 'Join Ladies That UX Málaga for an evening dedicated to inclusive digital design and accessibility with speaker Irene Puertas. April 7, 2026.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {breadcrumb}>
  <PageWrapper lang="en" path={path} client:load><Page /></PageWrapper>
</Layout>
