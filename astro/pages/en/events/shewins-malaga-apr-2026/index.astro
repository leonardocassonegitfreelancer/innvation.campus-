---
import Layout from '../../../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/en/events/SheWinsApr2026';
const path = '/en/events/shewins-malaga-apr-2026';
const title = 'SheWins Málaga: The Simple Rules of Money';
const description = 'Personal finance workshop with Alice Dickinson, Chartered Accountant. Learn the simple rules of money at Innovation Campus Málaga Palace. April 16, 2026.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {breadcrumb}>
  <PageWrapper lang="en" path={path} client:load><Page /></PageWrapper>
</Layout>
