---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/meeting-rooms/large-conference-room';
const title = 'Large Conference Room';
const description = 'Versatile conference room for up to 50 people (44 chairs). 48m² on the ground floor with projector, microphone, whiteboard and speaker. Catering and events available in Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <MeetingRoomPage roomSlug="large-conference-room" lang="en" client:load />
</RoomPageLayout>
