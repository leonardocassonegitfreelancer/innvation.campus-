---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/meeting-rooms/4th-floor-training-room';
const title = 'Training Room 4th Floor — Málaga Terrace';
const description = 'Training room on the 4th floor at Innovation Campus Málaga Terrace. Projector, whiteboard, high-speed WiFi and terrace access included.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <MeetingRoomPage roomSlug="4th-floor-training-room" lang="en" client:load />
</RoomPageLayout>
