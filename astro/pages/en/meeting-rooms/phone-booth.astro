---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/meeting-rooms/phone-booth';
const title = 'Phone Booth';
const description = 'Private soundproofed phone booth for 1 person. 1×1×2.30m pod on the ground floor at Innovation Campus Málaga Palace. Perfect for confidential calls and focused work.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <MeetingRoomPage roomSlug="phone-booth" lang="en" client:load />
</RoomPageLayout>
