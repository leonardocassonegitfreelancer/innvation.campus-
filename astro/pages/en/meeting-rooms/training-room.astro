---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/en/meeting-rooms/training-room';
const title = 'Training Room';
const description = 'Dedicated training room with classroom setup, projector, and all amenities for workshops and courses in Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="en">
  <MeetingRoomPage roomSlug="training-room" lang="en" client:load />
</RoomPageLayout>
