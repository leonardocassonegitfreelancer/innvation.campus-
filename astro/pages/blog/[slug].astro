---
import Layout from '../../layouts/Layout.astro';
import BlogPostIsland from '@/components/BlogPostIsland';
import { getBlogPost } from '@/data/blogPosts';

const { slug } = Astro.params;
const post = getBlogPost(slug ?? '');

const title = post?.title ?? 'Blog Post';
const description = post?.excerpt ?? 'Read this article on the Innovation Campus blog.';
const path = `/blog/${slug}`;
---
<Layout {title} {description} {path} noIndex={!post}>
  <BlogPostIsland slug={slug ?? ''} client:load />
</Layout>
