---
import Layout from '../../../layouts/Layout.astro';
import GalleryEventsPage from '@/pages/en/GalleryEvents';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/galleria/eventi';
const title = 'Galleria Eventi';
const description = 'Foto degli eventi comunitari, serate di networking, workshop e talk a Innovation Campus Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<Layout {title} {description} {path} {breadcrumb}>
  <GalleryEventsPage lang="it" client:load />
</Layout>
