---
import Layout from '../../layouts/Layout.astro';
import Navbar from '@/components/landing/Navbar';
import Footer from '../../components/Footer.astro';
import Olbia from '@/pages/en/Olbia';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/olbia';
const title = 'Spazio Coworking a Olbia';
const description = 'Uno spazio di coworking moderno a Olbia, Sardegna.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {alternates} {breadcrumb}>
  <div class="overflow-x-hidden">
    <Navbar lang="it" client:load />
    <Olbia lang="it" client:load />
    <Footer />
  </div>
</Layout>
