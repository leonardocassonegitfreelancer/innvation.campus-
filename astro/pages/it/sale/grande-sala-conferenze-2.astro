---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/sale/grande-sala-conferenze-2';
const title = 'Large Conference Room';
const description = 'Sala versatile per fino a 50 persone (44 sedie). 48m² al piano terra con proiettore, microfono, lavagna e altoparlante. Catering ed eventi disponibili a Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="it">
  <MeetingRoomPage roomSlug="large-conference-room" lang="it" client:load />
</RoomPageLayout>
