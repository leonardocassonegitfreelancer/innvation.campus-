---
import ServicePageLayout from '../../../components/ServicePageLayout.astro';
import { PageWrapper } from '@/lib/lang-context';
import TerraceIntro from '@/components/landing/TerraceIntro';
import TerraceSpaces from '@/components/landing/TerraceSpaces';
import TerraceIncludes from '@/components/landing/TerraceIncludes';
import TerraceGallery from '@/components/landing/TerraceGallery';
import ConferenceCTA from '@/components/landing/ConferenceCTA';
import serviceTerrace from '@/assets/service-terrace.webp';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/terrazza-privata';
const title = 'Terrazza Privata';
const subtitle = 'Uno spazio esterno esclusivo con opzioni di catering per i tuoi eventi e riunioni.';
const description = 'Uno spazio esterno esclusivo con opzioni di catering per i tuoi eventi e riunioni a Málaga.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<ServicePageLayout {title} {subtitle} {description} {path} {alternates} {breadcrumb} image={serviceTerrace} lang="it">
  <PageWrapper lang="it" path={path} client:load>
    <TerraceIntro />
    <TerraceSpaces />
    <TerraceIncludes />
    <TerraceGallery />
  </PageWrapper>
  <ConferenceCTA lang="it" client:visible />
</ServicePageLayout>
