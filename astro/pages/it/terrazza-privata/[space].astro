---
export const prerender = true;

import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import MeetingRoomPage from '@/components/landing/MeetingRoomPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

type SpaceId = "full-terrace" | "half-terrace";

const spaceMeta: Record<SpaceId, { title: string; description: string }> = {
  "full-terrace": { title: "Esperienza Terrazza Completa — Málaga Terrace", description: "Spazio esterno esclusivo sul rooftop per fino a 120 persone con vista panoramica sul mare, bar completo e catering su misura a Innovation Campus Málaga." },
  "half-terrace": { title: "Esperienza Mezza Terrazza — Málaga Terrace", description: "Mezza terrazza esclusiva sul rooftop per fino a 60 persone con vista sul mare, servizio bar e catering a Innovation Campus Málaga." },
};

export function getStaticPaths() {
  return [
    { params: { space: 'full-terrace' } },
    { params: { space: 'half-terrace' } },
  ];
}

const { space } = Astro.params as { space: SpaceId };
const meta = spaceMeta[space];
const path = `/it/terrazza-privata/${space}`;
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout title={meta.title} description={meta.description} {path} {breadcrumb} lang="it">
  <MeetingRoomPage roomSlug={space} lang="it" backUrl="/it/terrazza-privata" client:load />
</RoomPageLayout>
