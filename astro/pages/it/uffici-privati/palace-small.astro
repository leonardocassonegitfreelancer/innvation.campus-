---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/uffici-privati/palace-small';
const title = 'Ufficio Privato Piccolo — Málaga Palace';
const description = 'Un affascinante ufficio privato per 1–3 persone nel cuore storico di Málaga. Luce naturale, ingresso privato, WiFi ad alta velocità.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="it">
  <OfficeDetailPage officeSlug="palace-small" lang="it" client:load />
</RoomPageLayout>
