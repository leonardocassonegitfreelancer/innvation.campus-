---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/uffici-privati/terrace-large';
const title = 'Ufficio Privato Grande — Málaga Terrace';
const description = 'La suite ufficio premium all\'ultimo piano di Málaga Terrace con vista panoramica sul mare e sulla città. Completamente isolata per 9–20 persone.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="it">
  <OfficeDetailPage officeSlug="terrace-large" lang="it" client:load />
</RoomPageLayout>
