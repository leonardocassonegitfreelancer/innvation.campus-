---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import OfficeDetailPage from '@/components/landing/OfficeDetailPage';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/uffici-privati/terrace-small';
const title = 'Ufficio Privato Piccolo — Málaga Terrace';
const description = 'Un luminoso ufficio privato per 1–3 persone con vista oceano nella sede Málaga Terrace. Finitura moderna, luce del mare e tutti i servizi.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<RoomPageLayout {title} {description} {path} {breadcrumb} lang="it">
  <OfficeDetailPage officeSlug="terrace-small" lang="it" client:load />
</RoomPageLayout>
