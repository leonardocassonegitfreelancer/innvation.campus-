---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import AboutUs from '@/pages/en/AboutUs';
import aboutCampus from '@/assets/palace-outside-front.webp';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/chi-siamo';
const title = 'Chi Siamo';
const description = 'Innovation Campus crea spazi di lavoro ispiranti e coltiva comunità imprenditoriali internazionali in Spagna e Italia.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  subtitle="Spazi ispiratori. Comunità internazionale. Impatto reale."
  image={aboutCampus}
  lang="it"
>
  <AboutUs lang="it" client:load />
</ServicePageLayout>
