---
import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import EventsHub from '@/components/landing/EventsHub';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';

const path = '/it/eventi';
const title = 'Eventi Comunitari — Innovation Campus';
const description = 'Partecipa a workshop, talk, networking ed eventi comunitari a Innovation Campus Málaga.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---

<RoomPageLayout {title} {description} {path} {breadcrumb} lang="it">
  <EventsHub lang="it" client:load />
</RoomPageLayout>
