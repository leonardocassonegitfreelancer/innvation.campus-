---
import Layout from '../../../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/it/events/PowerTalksBApr2026';
const path = '/it/eventi/powertalks-malaga-apr-2026-b';
const title = 'PowerTalks Málaga — Secondo Meetup Aprile 2026';
const description = 'Talk brevi e ad alto impatto di founder e professionisti a Innovation Campus Málaga Palace. 29 Aprile 2026.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {breadcrumb}>
  <PageWrapper lang="it" path={path} client:load><Page /></PageWrapper>
</Layout>
