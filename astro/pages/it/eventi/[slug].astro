---
export const prerender = true;

import RoomPageLayout from '../../../components/RoomPageLayout.astro';
import EventDetail from '@/components/landing/EventDetail';
import { eventsDataset } from '@/data/events';

export function getStaticPaths() {
  return eventsDataset.map(e => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params as { slug: string };
const event = eventsDataset.find(e => e.slug === slug)!;
const tr = event.translations.it;

const title = `${tr.title} — Innovation Campus`;
const description = tr.excerpt;
const path = `/it/eventi/${slug}`;
const leadUrl = `/it/lead/event/${slug}`;
---

<RoomPageLayout {title} {description} {path} lang="it">
  <EventDetail {slug} lang="it" {leadUrl} client:load />
</RoomPageLayout>
