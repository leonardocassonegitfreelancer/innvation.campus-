---
import Layout from '../../../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/it/events/PowerTalksApr2026';
const path = '/it/eventi/powertalks-malaga-apr-2026';
const title = 'PowerTalks Málaga Meetup Aprile 2026';
const description = 'Unisciti a PowerTalks Málaga per un meetup Toastmasters di public speaking in inglese. Pratica, miglioramento e ispirazione. 15 Aprile 2026.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {breadcrumb}>
  <PageWrapper lang="it" path={path} client:load><Page /></PageWrapper>
</Layout>
