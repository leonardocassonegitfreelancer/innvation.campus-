---
import Layout from '../../../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/it/events/SheWinsApr2026';
const path = '/it/eventi/shewins-malaga-apr-2026';
const title = 'SheWins Málaga: Le Semplici Regole del Denaro';
const description = 'Workshop di finanza personale con Alice Dickinson, Dottore Commercialista. Impara le semplici regole del denaro a Innovation Campus Málaga Palace. 16 Aprile 2026.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {breadcrumb}>
  <PageWrapper lang="it" path={path} client:load><Page /></PageWrapper>
</Layout>
