---
import Layout from '../../../../layouts/Layout.astro';
import { PageWrapper } from '@/lib/lang-context';
import { generateBreadcrumbJsonLd } from '@/lib/i18n';
import Page from '@/pages/it/events/LadiesThatUXApr2026';
const path = '/it/eventi/ladies-that-ux-malaga-apr-2026';
const title = 'Ladies That UX Málaga: Design Digitale Inclusivo & Accessibilità';
const description = 'Unisciti a Ladies That UX Málaga per una serata dedicata al design digitale inclusivo e all\'accessibilità con la speaker Irene Puertas. 7 Aprile 2026.';
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<Layout {title} {description} {path} {breadcrumb}>
  <PageWrapper lang="it" path={path} client:load><Page /></PageWrapper>
</Layout>
