---
import ServicePageLayout from '../../components/ServicePageLayout.astro';
import ConferenceIntro from '@/components/landing/ConferenceIntro';
import ConferenceRooms from '@/components/landing/ConferenceRooms';
import EventSocialProof from '@/components/landing/EventSocialProof';
import ServicePhotoGrid from '../../components/ServicePhotoGrid.astro';
import QuoteSection from '../../components/QuoteSection.astro';
import ScrollAnimate from '../../components/ScrollAnimate.astro';
import { getAlternateLinks, generateBreadcrumbJsonLd } from '@/lib/i18n';
import serviceMeeting from '@/assets/big-conference-room-01.webp';
import serviceCoworking from '@/assets/service-coworking.webp';
import servicePrivate from '@/assets/service-private.webp';
import serviceCommunity from '@/assets/service-community.webp';
import serviceTerrace from '@/assets/service-terrace.webp';

const path = '/it/sale-riunioni';
const title = 'Sale Riunioni';
const subtitle = 'Spazi per riunioni professionali con opzioni di catering per team di tutte le dimensioni.';
const description = 'Spazi per riunioni professionali con opzioni di catering per team di tutte le dimensioni a Málaga.';
const alternates = getAlternateLinks(path);
const breadcrumb = generateBreadcrumbJsonLd(path, 'https://innovationcampus.biz');
---
<ServicePageLayout
  {title}
  {description}
  {path}
  {alternates}
  {breadcrumb}
  {subtitle}
  image={serviceMeeting}
  lang="it"
>
  <ConferenceIntro lang="it" client:load />
  <EventSocialProof lang="it" client:visible />
  <ConferenceRooms lang="it" client:visible />
  <QuoteSection lang="it" variant="meeting" />

  <ServicePhotoGrid
    eyebrow="Disponibile anche in questa location"
    title="Altri Spazi e Servizi"
    items={[
      { label: "Organizza il Tuo Evento", href: "/it/organizza-evento", image: serviceCommunity },
      { label: "Terrazza Privata", href: "/it/terrazza-privata", image: serviceTerrace },
      { label: "Coworking", href: "/it/coworking", image: serviceCoworking },
      { label: "Uffici Privati", href: "/it/uffici-privati", image: servicePrivate },
    ]}
  />

  <ScrollAnimate />
</ServicePageLayout>
