---
import Layout from '../layouts/Layout.astro';
import { getAlternateLinks } from '@/lib/i18n';
import ScrollAnimate from '../components/ScrollAnimate.astro';

// Astro static components (zero JS)
import AboutSnippet from '../components/AboutSnippet.astro';
import QuoteSection from '../components/QuoteSection.astro';
import LocationsSection from '../components/LocationsSection.astro';
import HomeCTA from '../components/HomeCTA.astro';
import FooterSection from '../components/Footer.astro';

// React islands (hydrated selectively)
import Navbar from '@/components/landing/Navbar';
import MainHero from '@/components/landing/MainHero';
import ServicesSection from '@/components/landing/ServicesSection';
import FAQSection from '@/components/landing/FAQSection';

const path = '/';
const title = 'Offices - Coworking - Events';
const description = 'Two coworking spaces in Málaga, Spain. One in the historic heart, one by the sea. Find your rhythm at Innovation/Campus.';
const alternates = getAlternateLinks(path);
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CoworkingSpace",
  "name": "Innovation Campus",
  "description": "Two coworking spaces in Málaga, Spain. One in the historic heart, one by the sea.",
  "url": "https://innovationcampus.biz",
  "address": [
    { "@type": "PostalAddress", "addressLocality": "Málaga", "addressCountry": "ES" },
    { "@type": "PostalAddress", "addressLocality": "Ancona", "addressCountry": "IT" }
  ],
  "openingHours": ["Mo-Th 09:30-18:30", "Fr 09:30-17:00"]
};
---
<Layout {title} {description} {path} {alternates} {jsonLd}>
  <main class="overflow-x-hidden">
    <!-- Navbar: interactive (mobile menu, dropdowns, lang switcher) — hydrate immediately -->
    <Navbar lang="en" client:load />

    <!-- Hero (dark) -->
    <MainHero client:load />

    <!-- Services (light) — visitors self-qualify immediately -->
    <ServicesSection client:visible />

    <!-- Quote (dark) -->
    <QuoteSection />

    <!-- Locations (light) -->
    <LocationsSection />

    <!-- Project / About (dark) -->
    <AboutSnippet lang="en" />

    <!-- FAQ — structured data for AI/featured snippets -->
    <FAQSection client:load />

    <!-- CTA (light) -->
    <HomeCTA lang="en" />

    <!-- Footer: pure HTML/CSS — zero JavaScript -->
    <FooterSection />
  </main>

  <!-- Lightweight scroll animation observer (~300 bytes) -->
  <ScrollAnimate />
</Layout>
