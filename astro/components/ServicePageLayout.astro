---
/**
 * ServicePageLayout — Astro component for consistent internal page layout.
 * Replaces the React ServicePageLayout.tsx.
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '@/components/landing/Navbar';
import Footer from './Footer.astro';

interface Props {
  title: string;
  subtitle: string;
  image: any;
  path: string;
  description: string;
  alternates?: any;
  breadcrumb?: any;
  lang?: "en" | "es" | "it";
}

const { title, subtitle, image, path, description, alternates, breadcrumb, lang = "en" } = Astro.props;
const imgSrc = typeof image === 'string' ? image : image.src;
---
<Layout {title} {description} {path} {alternates} {breadcrumb}>
  <main class="overflow-x-hidden">
    <!-- Navbar island -->
    <Navbar {lang} client:load />

    <!-- Hero section (Static) -->
    <section class="relative h-[60vh] min-h-[400px] flex items-end">
      <img src={imgSrc} alt={title} class="absolute inset-0 w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-neutral-dark via-neutral-dark/40 to-transparent"></div>
      <div class="relative z-10 max-w-6xl mx-auto px-6 pb-12 w-full">
        <a href={lang === "en" ? "/" : `/${lang}`} class="inline-flex items-center gap-2 text-white/70 hover:text-white text-sm font-body mb-4 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          {lang === "es" ? "Volver al inicio" : lang === "it" ? "Torna alla home" : "Back to Home"}
        </a>
        <h1 class="font-display text-4xl md:text-6xl font-bold text-primary-foreground">{title}</h1>
        <p class="font-body text-lg md:text-xl text-primary-foreground/70 mt-3 max-w-2xl">{subtitle}</p>
      </div>
    </section>

    <!-- Slot for page-specific content -->
    <slot />

    <Footer />
  </main>
</Layout>
