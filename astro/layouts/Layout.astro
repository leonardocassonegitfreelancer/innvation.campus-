---
import '../../src/index.css';

interface Alternates {
  en: string;
  es: string;
  it: string;
}

interface Props {
  title: string;
  description?: string;
  path?: string;
  ogImage?: string;
  jsonLd?: object | object[];
  breadcrumb?: object | null;
  noIndex?: boolean;
  alternates?: Alternates;
}

const {
  title,
  description = '',
  path = '/',
  ogImage = '/og-image.jpg',
  jsonLd,
  breadcrumb,
  noIndex = false,
  alternates,
} = Astro.props;

const BASE_URL = 'https://innovationcampus.biz';
const url = `${BASE_URL}${path}`;
const image = ogImage.startsWith('http') ? ogImage : `${BASE_URL}${ogImage}`;
const fullTitle = title.startsWith('Innovation Campus') ? title : `Innovation Campus | ${title}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={url} />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />

    {alternates && (
      <>
        <link rel="alternate" hreflang="en" href={`${BASE_URL}${alternates.en}`} />
        <link rel="alternate" hreflang="es" href={`${BASE_URL}${alternates.es}`} />
        <link rel="alternate" hreflang="it" href={`${BASE_URL}${alternates.it}`} />
        <link rel="alternate" hreflang="x-default" href={`${BASE_URL}${alternates.en}`} />
      </>
    )}

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Innovation Campus" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&family=Poppins:ital,wght@0,300;0,400;1,300;1,400&display=swap"
      rel="stylesheet"
    />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])} />}
    {breadcrumb && <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />}
  </head>
  <body>
    <slot />
  </body>
</html>
